# RETIRED: The API now runs inside crema-kiosk.service (merged process).
# This file is kept for reference only. Do not enable this service.

[Unit]
Description=CREMA API
After=network.target
Wants=network.target

[Service]
Type=simple
User=roncofaber
WorkingDirectory=/home/roncofaber/crema
ExecStart=/home/roncofaber/crema/venv/bin/crema serve
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
